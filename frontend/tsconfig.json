{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "module": "ESNext",
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx"
  ]
}